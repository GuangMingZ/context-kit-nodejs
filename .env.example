# 将此文件复制为 .env 并填入你的 API 密钥
# cp .env.example .env

# OpenAI API 密钥（04_compress_model.ts 使用，优先检测）
OPENAI_API_KEY=

# OpenAI 接口地址，可覆盖为兼容的 API 端点（如 Azure、本地代理）
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API 密钥（04_compress_model.ts 使用，OPENAI_API_KEY 未设置时作为备选）
ANTHROPIC_API_KEY=

# Anthropic 接口地址，可覆盖为兼容的 API 端点
# ANTHROPIC_BASE_URL=https://api.anthropic.com
